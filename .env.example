API_PORT=3001
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500

# sql = SQL login/password (DB_USER/DB_PASSWORD required)
# windows = Windows Integrated Auth (Trusted Connection) via msnodesqlv8
DB_AUTH=sql

# Prefer DB_HOST + DB_INSTANCE to avoid backslashes in .env files.
# Example for local SQL Express:
DB_HOST=localhost
DB_INSTANCE=SQLEXPRESS

# Alternative: single field (if you really want it)
# DB_SERVER=localhost\\SQLEXPRESS

DB_NAME=CryptoDonations
DB_USER=sa
DB_PASSWORD=YourStrongPassword
DB_ENCRYPT=false
DB_TRUST_CERT=true
