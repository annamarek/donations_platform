API_PORT=3001
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500

# sql = SQL login/password (DB_USER/DB_PASSWORD required)
# windows = Windows Integrated Auth (Trusted Connection)
DB_AUTH=windows

# Recommended (no backslashes needed):
DB_HOST=localhost
DB_INSTANCE=SQLEXPRESS

# If you use default instance / custom port instead, comment DB_INSTANCE and use DB_PORT:
# DB_HOST=localhost
# DB_PORT=1433

DB_NAME=Donations

# SQL Authentication login (must exist in SQL Server)
DB_USER=
DB_PASSWORD=

DB_ENCRYPT=false
DB_TRUST_CERT=true
